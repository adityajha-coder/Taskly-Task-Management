{
    "rewrites": [
        {
            "source": "/(.*)",
            "destination": "/Frontend/$1"
        }
    ],
    "headers": [
        {
            "source": "/Frontend/(.*)",
            "headers": [
                {
                    "key": "Cache-Control",
                    "value": "public, max-age=0, must-revalidate"
                }
            ]
        }
    ]
}